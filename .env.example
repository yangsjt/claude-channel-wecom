# WeCom Channel Plugin Configuration
# Copy this file to mcp-dev.json and fill in your credentials

# Mode: "aibot" (AI Bot / 智能机器人) or "agent" (Self-built App / 自建应用)
WECOM_MODE=aibot

# Required for both modes
WECOM_TOKEN=your_token_here
WECOM_ENCODING_AES_KEY=your_43_char_encoding_aes_key_here

# Required for Agent mode only
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=

# Optional
WECOM_CALLBACK_PORT=8788
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
